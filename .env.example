# Cal.com integration (optional — mock slots used when not configured)
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=your_event_type_id

# Vercel Blob — required on Vercel so runtime JSON data survives deploys
# Create a store in the Vercel dashboard (Storage → Blob) or: npx vercel blob store add
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URIs (add all that you use):
#   http://localhost:3000/api/auth/callback/google
#   https://www.verlinlabs.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
AUTH_SECRET=generate_with_openssl_rand_base64_32
# Canonical site URL — required in production (use www if that is your primary domain)
AUTH_URL=http://localhost:3000

# Search engine verification (paste tokens from Search Console / Bing Webmaster)
# GOOGLE_SITE_VERIFICATION=your_google_html_meta_content_token
# BING_SITE_VERIFICATION=your_bing_msvalidate_token
# INDEXNOW_API_SECRET=generate_a_long_random_string
# After deploy: POST /api/indexnow with Authorization: Bearer <INDEXNOW_API_SECRET>
# Legacy alias (optional; Auth.js reads AUTH_URL first)
# NEXTAUTH_URL=http://localhost:3000

# Weekly news ingest API (for Grok scheduled tasks / automation)
# POST /api/news/updates with Authorization: Bearer <key>
NEWS_INGEST_API_KEY=generate_a_long_random_string
# POST /api/newsletter/publish with Authorization: Bearer <key>
NEWS_PUBLISH_API_KEY=generate_another_long_random_string
# Vercel Cron + /api/cron/newsletter (Sunday auto-publish)
CRON_SECRET=generate_cron_secret

# Newsletter MCP — Grok scheduled tasks, Claude, Cursor
# GET  /api/mcp/newsletter              (discovery)
# POST /api/mcp/newsletter/publish-weekly  (one-shot: generate + publish + email)
NEWSLETTER_MCP_API_KEY=generate_a_long_random_string

# Resend — required for newsletter PDFs and password reset emails
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL=contact@verlinlabs.com
NEWSLETTER_FROM_EMAIL=Verlin Labs <contact@verlinlabs.com>
AUTH_FROM_EMAIL=Verlin Labs <contact@verlinlabs.com>

# ---------------------------------------------------------------------------
# Site chatbot — FREE providers only (paid APIs are not supported)
# ---------------------------------------------------------------------------
# 1) RECOMMENDED: Groq free tier — Llama 3.3 70B (fast, works great on Vercel)
#    https://console.groq.com → API Keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
#
# 2) ALTERNATIVE: Google Gemini Flash free tier
#    https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
#
# Optional force: CHAT_LLM_PROVIDER=groq|gemini
# Without any free key, the bot uses trained FAQ answers only (still free).

# 21st.dev MCP (https://21st.dev/settings/api-keys) — used by Grok .grok/config.toml
# API_KEY_21ST=your_21st_api_key

# LinkedIn OAuth (Sign In with LinkedIn using OpenID Connect) — optional
# LinkedIn Developer Portal → your app → Auth tab → enable "Sign In with LinkedIn using OpenID Connect"
# Authorized redirect URL: https://www.verlinlabs.com/api/auth/callback/linkedin
# Without these set, the LinkedIn sign-in button shows "not connected yet" instead of erroring.
# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Marketing Board — direct integration, no vendor (Meta Graph API + LinkedIn Community Management API)
# Without these set, /admin/marketing shows "not set up yet" instead of erroring.
#
# Meta (covers both Instagram and Facebook — one app, one OAuth flow):
# developers.facebook.com → create an app → add "Facebook Login for Business"
# Request permissions: pages_show_list, pages_manage_posts, pages_read_engagement,
#   instagram_basic, instagram_content_publish
# Since this only posts to Verlin Labs' own Page/Instagram account (not third-party
# businesses), add the admin as an App Role under App Roles → Roles to skip the
# multi-week App Review wait for this single-company use case.
# Redirect URI: https://www.verlinlabs.com/api/admin/marketing/connect/meta/callback
# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret
#
# LinkedIn organization posting — a SEPARATE app/credentials from LINKEDIN_CLIENT_ID
# above (that one is just for user sign-in; this one needs w_organization_social,
# a materially different and more sensitive permission LinkedIn reviews separately).
# linkedin.com/developers → create an app tied to the Verlin Labs Company Page →
# request the "Community Management API" product (two-tier review: Development
# Tier works immediately for testing; apply for Standard Tier for full volume).
# Redirect URL: https://www.verlinlabs.com/api/admin/marketing/connect/linkedin/callback
# LINKEDIN_ORG_CLIENT_ID=your_linkedin_org_client_id
# LINKEDIN_ORG_CLIENT_SECRET=your_linkedin_org_client_secret

