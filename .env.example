# Cal.com integration (optional ‚Äî mock slots used when not configured)
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=your_event_type_id

# Vercel Blob ‚Äî required on Vercel so runtime JSON data survives deploys
# Create a store in the Vercel dashboard (Storage ‚Üí Blob) or: npx vercel blob store add
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Google OAuth (Google Cloud Console ‚Üí APIs & Services ‚Üí Credentials)
# Authorized redirect URIs (add all that you use):
#   http://localhost:3000/api/auth/callback/google
#   https://www.verlinlabs.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
AUTH_SECRET=generate_with_openssl_rand_base64_32
# Canonical site URL ‚Äî required in production (use www if that is your primary domain)
AUTH_URL=http://localhost:3000

# Search engine verification (paste tokens from Search Console / Bing Webmaster)
# GOOGLE_SITE_VERIFICATION=your_google_html_meta_content_token
# BING_SITE_VERIFICATION=your_bing_msvalidate_token
# INDEXNOW_API_SECRET=generate_a_long_random_string
# After deploy: POST /api/indexnow with Authorization: Bearer <INDEXNOW_API_SECRET>
# Legacy alias (optional; Auth.js reads AUTH_URL first)
# NEXTAUTH_URL=http://localhost:3000

# Weekly news ingest API (for Grok scheduled tasks / automation)
# POST /api/news/updates with Authorization: Bearer <key>
NEWS_INGEST_API_KEY=generate_a_long_random_string
# POST /api/newsletter/publish with Authorization: Bearer <key>
NEWS_PUBLISH_API_KEY=generate_another_long_random_string
# Vercel Cron + /api/cron/newsletter (Sunday auto-publish)
CRON_SECRET=generate_cron_secret

# Newsletter MCP ‚Äî Grok scheduled tasks, Claude, Cursor
# GET  /api/mcp/newsletter              (discovery)
# POST /api/mcp/newsletter/publish-weekly  (one-shot: generate + publish + email)
NEWSLETTER_MCP_API_KEY=generate_a_long_random_string

# Resend ‚Äî required for newsletter PDFs and password reset emails
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL=contact@verlinlabs.com
NEWSLETTER_FROM_EMAIL=Verlin Labs <contact@verlinlabs.com>
AUTH_FROM_EMAIL=Verlin Labs <contact@verlinlabs.com>

# ---------------------------------------------------------------------------
# Site chatbot ‚Äî FREE providers only (paid APIs are not supported)
# ---------------------------------------------------------------------------
# 1) RECOMMENDED: Groq free tier ‚Äî Llama 3.3 70B (fast, works great on Vercel)
#    https://console.groq.com ‚Üí API Keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
#
# 2) ALTERNATIVE: Google Gemini Flash free tier
#    https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
#
# Optional force: CHAT_LLM_PROVIDER=groq|gemini
# Without any free key, the bot uses trained FAQ answers only (still free).

# 21st.dev MCP (https://21st.dev/settings/api-keys) ó used by Grok .grok/config.toml
# API_KEY_21ST=your_21st_api_key

