{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "verlinlabs.com" }],
      "destination": "https://www.verlinlabs.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/newsletter",
      "schedule": "30 3 * * 0"
    },
    {
      "path": "/api/cron/indexnow",
      "schedule": "0 4 * * *"
    }
  ]
}